# =============================================================================
# ReciPal Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database (Supabase Postgres) ---
# Connection string for your Supabase PostgreSQL database
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Session ---
# Secret key for encrypting Express sessions (use a random string, 32+ chars)
SESSION_SECRET=

# --- Supabase ---
# Your Supabase project URL (e.g., https://nknawctvorkhhlcvbcbv.supabase.co)
SUPABASE_URL=
# Supabase service role key (NOT the anon key — this is server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# --- FatSecret API ---
# OAuth2 credentials from https://platform.fatsecret.com/
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# --- OpenAI ---
# API key for GPT-4o (used for scaled steps, insights, recipe classification)
OPENAI_API_KEY=
# Optional: Override the OpenAI base URL (leave blank for default)
# OPENAI_BASE_URL=

# --- FatSecret Relay (Required) ---
# FatSecret requires a static IP; requests are routed through a relay proxy
RELAY_URL=
RELAY_KEY=

# --- Optional: Spoonacular ---
# Fallback recipe source (app runs in demo mode without this)
# SPOONACULAR_API_KEY=

# --- Optional: Instacart ---
# Set to "development" or "production"
# INSTACART_API_ENV=development

# --- Server ---
# Port for the Express server (default: 5000)
# PORT=5000
# NODE_ENV=development
